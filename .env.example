# BenchmarkWatcher Environment Configuration
# Copy this file to .env and fill in your API keys

# FRED API Key (free)
# Get yours at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# EIA API Key (free)
# Get yours at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# USDA NASS API Key (free)
# Get yours at: https://quickstats.nass.usda.gov/api
USDA_API_KEY=your_usda_api_key_here

# Internal API key for /internal/api/commodities (used by bots)
INTERNAL_API_KEY=change_me

# Optional hardening: Flask-Limiter (no extra service required)
# Keep memory:// to use only in-process storage.
RATELIMIT_STORAGE_URI=memory://
PUBLIC_API_LIST_RATE_LIMIT=60 per minute
PUBLIC_API_DETAIL_RATE_LIMIT=120 per minute
INTERNAL_API_RATE_LIMIT=30 per minute

# Dev server debug flag used by run.py (keep false in production)
FLASK_DEBUG=false
